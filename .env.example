# Spotify Developer App credentials
# Register at https://developer.spotify.com/dashboard
SPOTIFY_CLIENT_ID=
SPOTIFY_CLIENT_SECRET=
# NOTE: Use 127.0.0.1 (not localhost) — Spotify rejects 'localhost' as a
# redirect URI since their April 2025 policy update. The literal IPv4
# loopback is required for HTTP redirect URIs.
SPOTIFY_REDIRECT_URI=http://127.0.0.1:8888/callback

# Optional: override the database path (default: ./data/music.db)
# MUSIC_DB_PATH=/path/to/music.db
