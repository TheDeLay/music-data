# Python
__pycache__/
*.py[cod]
*$py.class
.venv/
venv/
*.egg-info/
.pytest_cache/

# Secrets
.env
.spotify_token.json
*.pem
*.key

# Data — never commit listening history or DB
data/raw/
data/*.db
data/*.db-journal
data/*.db-wal
data/*.db-shm

# OS
.DS_Store
Thumbs.db

# FUSE/SyncThing shadow files — created when a file is unlinked while still
# open by another process (common when SyncThing replicates over a file
# something else is reading). Harmless leftovers; should never be committed.
.fuse_hidden*

# Editors
.vscode/
.idea/
*.swp
*.swo

# Generated summaries — these CAN be committed if you want, but default to ignoring
# since they may contain PII (your listening habits)
summaries/*.md
!summaries/.gitkeep

# Per-run enrichment logs — auto-generated, may contain track URIs and
# 429 timestamps that fingerprint your Spotify dev app. Local-only.
logs/
