# Python
__pycache__/
*.py[cod]
*$py.class
.venv/
venv/
*.egg-info/
.pytest_cache/

# Secrets
.env
.spotify_token.json
*.pem
*.key

# Data — never commit listening history or DB
data/raw/
data/*.db
data/*.db-journal
data/*.db-wal
data/*.db-shm

# OS
.DS_Store
Thumbs.db

# FUSE shadow files — created when a file is unlinked while still
# open by another process. Harmless leftovers; should never be committed.
.fuse_hidden*

# Editors
.vscode/
.idea/
*.swp
*.swo

# Generated summaries — these CAN be committed if you want, but default to ignoring
# since they may contain PII (your listening habits)
summaries/*.md
!summaries/.gitkeep

# Per-run enrichment logs — auto-generated, may contain track URIs and
# 429 timestamps that fingerprint your Spotify dev app. Local-only.
logs/

# Personal classifier rules — your taxonomy is yours. Only the public
# example file is committed. Copy it to config/my-tags.yaml (or any
# other name) and git will leave your personal rules alone.
config/*.yaml
!config/example-tags.yaml
